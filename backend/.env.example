PORT=3100

# Required for real local transcription. Point this to your whisper.cpp CLI binary.
# Windows example: C:\tools\whisper.cpp\build\bin\Release\whisper-cli.exe
# macOS/Linux example: /Users/me/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_BIN=

# Required for real local transcription. Point this to a downloaded whisper.cpp model.
# Example: C:\tools\whisper.cpp\models\ggml-base.en.bin
WHISPER_CPP_MODEL=

# Optional. Defaults to ffmpeg on PATH. Required because Chrome records WebM/Opus.
FFMPEG_BIN=ffmpeg

# Optional. CPU-only is safer for a local Windows prototype. Set true only if your whisper.cpp build supports GPU.
WHISPER_CPP_USE_GPU=false

# Optional. Keep English for faster/more stable call-answer classification.
WHISPER_CPP_LANGUAGE=en

# Optional. Increase if using a larger local model on a slower machine.
WHISPER_CPP_TIMEOUT_MS=120000

# Optional. Useful for testing classification without running whisper.cpp.
MOCK_TRANSCRIPT=
